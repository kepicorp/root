# Copy to `.env` and fill in. `docker compose` and the dev scripts both
# read from this file automatically.

# Port the HTTP + WebSocket server listens on.
PORT=8787

# Where the server writes per-room JSON snapshots.
DATA_DIR=./data/rooms

# Rooms idle longer than this are auto-pruned every 6h.
MAX_ROOM_AGE_DAYS=90

# Admin page password. Leave UNSET (or empty) to disable /admin entirely.
# Set this to a non-trivial string to enable the admin UI at /admin.
# ADMIN_PASSWORD=change-me
